#define ZMK_POINTING_DEFAULT_MOVE_VAL 400  // 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 25   // 10

#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <behaviors/naginata.dtsi>
#include <behaviors/unicode.dtsi>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/rgb.h>

&mmv_input_listener { input-processors = <&zip_xy_scaler 2 1>; };

&msc_input_listener { input-processors = <&zip_scroll_scaler 2 1>; };

&msc {
    acceleration-exponent = <1>;      // 0
    time-to-max-speed-ms = <100>;       // 300
    delay-ms = <0>;                   // 0
};

&mmv {
    time-to-max-speed-ms = <500>;
    acceleration-exponent = <1>;
    trigger-period-ms = <16>;
};

&uc { default-mode = <UC_MODE_WIN_COMPOSE>; };

/ {
    macros {
        ng_on: ng_on {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_tap>,
                <&kp LANGUAGE_1 &kp INTERNATIONAL_4 &to 3>,
                <&macro_press>,
                <&kp LCTRL &kp LSHIFT>,
                <&macro_tap>,
                <&kp NUMBER_1>,
                <&macro_release>,
                <&kp LCTRL &kp LSHIFT>;
        };

        ng_off: ng_off {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_tap>,
                <&kp LANGUAGE_2 &kp INTERNATIONAL_5 &to 0>,
                <&macro_press>,
                <&kp LCTRL &kp LSHIFT>,
                <&macro_tap>,
                <&kp N0>,
                <&macro_release>,
                <&kp LCTRL &kp LSHIFT>;
        };

        tog_ime: tog_ime {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_ALT>,
                <&macro_tap>,
                <&kp GRAVE>,
                <&macro_release>,
                <&kp LEFT_ALT>;

            label = "TOG_IME";
        };
    };

    sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&left_encoder>;
        triggers-per-rotation = <20>;
    };

    behaviors {
        td0: td0 {
            compatible = "zmk,behavior-tap-dance";
            display-name = "Shift/Caps Lock Tap Dance";
            #binding-cells = <0>;
            bindings = <&kp LEFT_SHIFT>, <&kp CAPS>;
        };
    };

    rgb_encoder: rgb_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&rgb_ug RGB_BRI>, <&rgb_ug RGB_BRD>;
    };

    scroll_encoder: scroll_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;

        tap-ms = <100>;
    };

    combos {
        compatible = "zmk,combos";

        combo_ng_on {
            timeout-ms = <300>;
            key-positions = <16 17 23 24>; // H, Jのキー位置に書き換えてください
            bindings = <&ng_on>;
            layers = <0>; // デフォルトレイヤーが0の前提
        };

        combo_ng_off {
            timeout-ms = <300>;
            key-positions = <23 24 17 16>; // F, Gのキー位置に書き換えてください
            bindings = <&ng_off>;
            layers = <3>; // デフォルトレイヤーが0、薙刀式レイヤーが1の前提
        };

        on_vie {
            bindings = <&to 1>;
            key-positions = <15 16 24 25>;
            layers = <0>;
        };

        off_vie {
            bindings = <&to 0>;
            key-positions = <15 16 24 25>;
            layers = <1>;
        };

        to_win_compose {
            bindings = <&uc UC_SET_WIN_COMPOSE>;
            key-positions = <41 40 0>;
            layers = <1>;
        };

        to_win_alt {
            bindings = <&uc UC_SET_WIN_ALT>;
            key-positions = <41 40 1>;
            layers = <1>;
        };

        to_mac {
            bindings = <&uc UC_SET_MACOS>;
            key-positions = <41 40 2>;
            layers = <1>;
        };

        to_linux {
            bindings = <&uc UC_SET_LINUX>;
            key-positions = <41 40 3>;
            layers = <1>;
        };

        combo_dd {
            timeout-ms = <40>;
            key-positions = <32 45>;
            bindings = <&uc 0x0111 0x0110>;
            layers = <1>;
        };

        combo_a_huyen {
            timeout-ms = <40>;
            key-positions = <14 23>;
            bindings = <&uc 0x00E0 0x00C0>;
            layers = <1>;
        };

        combo_a_sac {
            timeout-ms = <40>;
            key-positions = <14 24>;
            bindings = <&uc 0x00E1 0x00C1>;
            layers = <1>;
        };

        combo_a_nang {
            timeout-ms = <40>;
            key-positions = <14 25>;
            bindings = <&uc 0x1EA1 0x1EA0>;
            layers = <1>;
        };

        combo_a_nga {
            timeout-ms = <40>;
            key-positions = <14 9>;
